<?xml version="1.0" encoding="UTF-8" ?>
<NotepadPlus>
	<functionList>
		<!-- ======================================================== [ AHK ] -->
		<!-- AHK - AutoHotKey Language                -->

		<parser id="ahk_function" displayName="AHK" commentExpr="((?<=[\s]);.*?$)">
			<function
				mainExpr="\/\*\s*\n?((?:(?=.*\|).*?\n?)*?)\*\/|(^[ \t]*#HotIf\s+\w*\(.*\))|(^[ \t]*([\w#!^+&<>*~$]+)\([^)]*\)[ \t]*\{)">
				<functionName>
					<nameExpr expr="\|.*\w*|#HotIf\s+\w*\(.*\)|(^[ \t]*([\w#!^+&<>*~$]+)\([^)]*\)[ \t]\{)"/>
				</functionName>
			</function>
		</parser>
	</functionList>
</NotepadPlus>