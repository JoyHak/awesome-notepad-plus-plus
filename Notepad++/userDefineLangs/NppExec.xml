            <Keywords name="Folders in comment, open"></Keywords>
            <Keywords name="Folders in comment, middle"></Keywords>
            <Keywords name="Folders in comment, close"></Keywords>
            <Keywords name="Keywords1">env_set env_unset set_env unset_env set unset then for else local nul cmd ps powershell</Keywords>
            <Keywords name="Keywords2">ctrl ctrlc ctrlbreak break disable enable keep con sci fg bg</Keywords>
            <Keywords name="Keywords3">:: : nppexec: nppexec:: - -- /</Keywords>
            <Keywords name="Keywords4">about help &quot;help all&quot; manual ver cd chr clip_settext cls con_colour con_filter con_load con_loadfrom con_save con_saveto dir echo exit goto inputbox label local messagebox normpath npe_cmdalias npe_console npe_debug npe_debuglog fileexists direxists npe_noemptyvars npe_queue npe_sendmsgbuflen npp_close npp_console npp_exec npp_menucommand npp_open npp_run npp_save npp_saveall npp_saveas npp_sendmsg npp_sendmsgex npp_setfocus npp_switch ord ordx proc_signal sci_find sci_replace sci_sendmsg sel_load sel_loadfrom sel_save sel_saveto sel_settext sel_settext+ set sleep strfind strfromhex strlen strlens strlensci strlenu strlenutf8 strlower strreplace strrfind strquote strtohex strunquote strupper substr text_load text_loadfrom text_save text_saveto abs acos acosh arg asin asinh atan atan2 atanh cbrt ceil conj cos cosh cot csc eval exp exp2 floor hypot if imag int log log10 log2 max min polar pow real sec sin sinh sqrt tan tanh trunc npp_exectext proc_input strexpand strunescape strescape</Keywords>
            <Keywords name="Keywords5"></Keywords>
            <Keywords name="Keywords6"></Keywords>
            <Keywords name="Keywords7"></Keywords>
            <Keywords name="Keywords8"></Keywords>
