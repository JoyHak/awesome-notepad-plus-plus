<NotepadPlus>
    <UserLang name="Syncovery log" ext="log" udlVersion="2.1">
        <Settings>
            <Global caseIgnored="yes" allowFoldOfComments="no" foldCompact="no" forcePureLC="0" decimalSeparator="0" />
            <Prefix Keywords1="no" Keywords2="no" Keywords3="yes" Keywords4="yes" Keywords5="no" Keywords6="no" Keywords7="no" Keywords8="no" />
        </Settings>
        <KeywordLists>
            <Keywords name="Comments">00Skipping 01 02 03 04</Keywords>
            <Keywords name="Numbers, prefix1">: v x w</Keywords>
            <Keywords name="Numbers, prefix2"></Keywords>
            <Keywords name="Numbers, extras1"></Keywords>
            <Keywords name="Numbers, extras2"></Keywords>
            <Keywords name="Numbers, suffix1">MB</Keywords>
            <Keywords name="Numbers, suffix2">kb</Keywords>
            <Keywords name="Numbers, range">:</Keywords>
            <Keywords name="Operators1">, = . ( ) - &gt; % &quot; * =&gt; -&gt; : ( ) ; / \ |</Keywords>
            <Keywords name="Operators2"></Keywords>
            <Keywords name="Folders in code1, open"></Keywords>
            <Keywords name="Folders in code1, middle"></Keywords>
            <Keywords name="Folders in code1, close"></Keywords>
            <Keywords name="Folders in code2, open"></Keywords>
            <Keywords name="Folders in code2, middle"></Keywords>
            <Keywords name="Folders in code2, close"></Keywords>
            <Keywords name="Folders in comment, open"></Keywords>
            <Keywords name="Folders in comment, middle"></Keywords>
            <Keywords name="Folders in comment, close"></Keywords>
            <Keywords name="Keywords1"></Keywords>
            <Keywords name="Keywords2">copy restart start upload available connecting log run scan move creat renam copi after before need upd now time open Delet confirm mis compar Binar Previous Verif Refresh Using read Took [WARNING] [WARN] [HACKING]</Keywords>
            <Keywords name="Keywords3">\u #</Keywords>
            <Keywords name="Keywords4">false unknown ok min max success fast slow complete end duration Connected 0x [FAILED] [FAIL]</Keywords>
            <Keywords name="Keywords5">SUMMARY&#x000D;&#x000A;Total</Keywords>
            <Keywords name="Keywords6">L2R L-&gt;R L&#x2192;R R&#x2192;L kb data R2L MB/s kB/sec MB kb hour second internet protocol name last additional sub smart day week year byte ltime rtime read-only cmLeft cmright System Exact Mirror Mode unattended destination [NOTE] in&#x000D;&#x000A;</Keywords>
            <Keywords name="Keywords7">[ERROR]&#x000D;&#x000A;[CRITICAL]&#x000D;&#x000A;error &#x000D;&#x000A;ERROR:&#x000D;&#x000A;errors&#x000D;&#x000A;problems&#x000D;&#x000A;exist&#x000D;&#x000A;INCOMPLETE:&#x000D;&#x000A;failed</Keywords>
            <Keywords name="Keywords8">no not yes off checked FOUND &#x000D;&#x000A;right left right: left:&#x000D;&#x000A;hand path side side: &#x000D;&#x000A;Direction&#x000D;&#x000A;succeeded&#x000D;&#x000A;success</Keywords>
            <Keywords name="Delimiters">00` 01 02((`EOL)) 03 04 05 06 07 08 09ids 10 11((EOL)) 12verifying 13 14((EOL)) 15&quot; 16 17((&quot; EOL)) 18ignoring 19 20((EOL)) 21 22 23</Keywords>
        </KeywordLists>
        <Styles>
            <WordsStyle name="DEFAULT" fgColor="999999" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="COMMENTS" fgColor="645E80" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="LINE COMMENTS" fgColor="4D4D53" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="NUMBERS" fgColor="0077EE" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS1" fgColor="00A452" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS2" fgColor="FBD144" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS3" fgColor="FF0080" bgColor="1E1E21" colorStyle="1" fontName="Maple Mono NF CN" fontStyle="0" fontSize="12" nesting="0" />
            <WordsStyle name="KEYWORDS4" fgColor="FD5785" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS5" fgColor="FF6B2D" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="5" fontSize="20" nesting="0" />
            <WordsStyle name="KEYWORDS6" fgColor="8080C0" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS7" fgColor="FD0234" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS8" fgColor="FD57B7" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="1" nesting="0" />
            <WordsStyle name="OPERATORS" fgColor="972857" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="FOLDER IN CODE1" fgColor="A667AD" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="FOLDER IN CODE2" fgColor="933589" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="FOLDER IN COMMENT" fgColor="000000" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS1" fgColor="FF0080" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="3" nesting="66813" />
            <WordsStyle name="DELIMITERS2" fgColor="FF80FF" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="1" nesting="50331648" />
            <WordsStyle name="DELIMITERS3" fgColor="00A452" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="1278" />
            <WordsStyle name="DELIMITERS4" fgColor="404040" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS5" fgColor="4D4D53" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS6" fgColor="FF8040" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS7" fgColor="515151" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS8" fgColor="000000" bgColor="1E1E21" colorStyle="1" fontName="JetBrains Mono" fontStyle="0" nesting="0" />
        </Styles>
    </UserLang>
</NotepadPlus>
